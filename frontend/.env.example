# ===== VERCEL FRONTEND CONFIGURATION =====

# API endpoint - set this to your Hugging Face Spaces backend URL
VITE_API_URL=https://YOUR-USERNAME-riskshield-bfsi-x.hf.space

# Supabase (for optional real-time features - direct connection from frontend)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Environment
VITE_ENVIRONMENT=production

# Optional: Tracking/Analytics
VITE_ENABLE_ANALYTICS=true
