# ===== DATABASE CONFIGURATION =====
# SQLite (Default - Local Development) - NO SETUP NEEDED
DATABASE_URL=sqlite:///./riskshield.db

# PostgreSQL/Supabase (Optional - Production)
# To use Supabase instead of SQLite, uncomment and fill these:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.supabase.co:5432/postgres
# SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
# SUPABASE_KEY=YOUR-ANON-KEY
# DATABASE_POOL_MAX=10

# ===== MODEL AND ENGINE THRESHOLDS =====
FRAUD_THRESHOLD=0.6
SECURITY_TRAP_THRESHOLD=1.0
CORRELATION_WINDOW_SECONDS=900

# ===== AUTHENTICATION & SECURITY =====
SECRET_KEY=riskshield-bfsi-x-super-secret-key-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== OPTIONAL: GEMINI API FOR EXPLANATIONS =====
# Leave empty to use template-based explanations
GEMINI_API_KEY=

# ===== FEATURE FLAGS =====
ENABLE_REAL_TIME_ALERTS=false
ENABLE_AUDIT_LOGGING=false
ENABLE_RLS=false
